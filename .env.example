# Copy this file to .env and fill in your bot's token.
# (The real .env for Shiketsu High is already provided alongside this file
# with everything filled in - this example is just for reference / reuse.)

DISCORD_TOKEN=your-bot-token-here

GUILD_ID=1369252646581436497
LOG_CHANNEL_ID=1456896912350515252
TRAINING_CHANNEL_ID=1456896908067999807
ASK_FOR_HELP_CHANNEL_ID=1456896903026311253

# Your Discord user ID. The bot DMs this person ~30 minutes before it's about
# to restart (as part of the ~6h GitHub Actions cycle), with a button to
# reboot early instead of waiting. Leave blank to disable this feature.
OWNER_ID=1040989419081048124

# How many minutes a single run is allowed to last before the workflow's
# `timeout` command kills it. Must match the value used in keep-alive.yml.
# Only relevant when hosted via GitHub Actions - ignored for local runs.
TIMEOUT_MINUTES=350

# Comma-separated role IDs. Members with any of these roles (or Administrator
# permission) can use moderation commands.
MOD_ROLE_IDS=1524460895823204414,1524460891515650069

# Comma-separated role IDs. Members with any of these roles (or a mod role,
# or Administrator) can use /host_training and /cancel_training.
TRAINER_ROLE_IDS=1456896815826997309,1456896817135353856
